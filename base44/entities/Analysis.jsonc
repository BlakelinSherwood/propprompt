{
  "name": "Analysis",
  "type": "object",
  "description": "One record per AI analysis run. Contains all intake data and output references.",
  "properties": {
    "org_id": {
      "type": "string"
    },
    "run_by_email": {
      "type": "string"
    },
    "on_behalf_of_email": {
      "type": "string"
    },
    "assessment_type": {
      "type": "string",
      "enum": [
        "listing_pricing",
        "cma",
        "buyer_intelligence",
        "investment_analysis",
        "rental_analysis",
        "client_portfolio",
        "price_reduction_review",
        "custom"
      ]
    },
    "property_type": {
      "type": "string",
      "enum": [
        "single_family",
        "condo",
        "multi_family",
        "land"
      ]
    },
    "location_class": {
      "type": "string",
      "enum": [
        "urban_core",
        "inner_suburb",
        "outer_suburb",
        "coastal",
        "rural"
      ]
    },
    "ai_platform": {
      "type": "string",
      "enum": [
        "claude",
        "chatgpt",
        "gemini",
        "perplexity",
        "grok"
      ]
    },
    "ai_model": {
      "type": "string"
    },
    "output_format": {
      "type": "string",
      "enum": [
        "narrative",
        "structured",
        "bullets"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_progress",
        "complete",
        "listed",
        "sold",
        "archived",
        "anomaly_flagged"
      ],
      "default": "draft"
    },
    "is_private": {
      "type": "boolean",
      "default": false
    },
    "collection_id": {
      "type": "string"
    },
    "intake_data": {
      "type": "object"
    },
    "followup_answers": {
      "type": "object"
    },
    "prompt_assembled": {
      "type": "string"
    },
    "output_text": {
      "type": "string"
    },
    "output_json": {
      "type": "object"
    },
    "output_pdf_url": {
      "type": "string"
    },
    "output_pptx_url": {
      "type": "string"
    },
    "drive_file_id": {
      "type": "string"
    },
    "drive_url": {
      "type": "string"
    },
    "drive_sync_status": {
      "type": "string",
      "enum": [
        "not_synced",
        "synced",
        "failed",
        "pending"
      ],
      "default": "not_synced"
    },
    "last_exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_export_format": {
      "type": "string"
    },
    "tokens_used": {
      "type": "integer"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "crm_push_status": {
      "type": "string",
      "enum": [
        "not_pushed",
        "pushed",
        "failed"
      ],
      "default": "not_pushed"
    },
    "compliance_flagged": {
      "type": "boolean",
      "default": false
    },
    "compliance_flag_reason": {
      "type": "string"
    },
    "selected_modules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "include_migration": {
      "type": "boolean",
      "default": false
    },
    "include_archetypes": {
      "type": "boolean",
      "default": false
    },
    "total_credits_used": {
      "type": "number"
    },
    "listed_date": {
      "type": "string",
      "format": "date"
    },
    "list_price": {
      "type": "number"
    },
    "sale_date": {
      "type": "string",
      "format": "date"
    },
    "sale_price": {
      "type": "number"
    },
    "dom_alert_threshold": {
      "type": "integer"
    },
    "price_reduction_alert_sent": {
      "type": "boolean",
      "default": false
    },
    "ensemble_mode_used": {
      "type": "boolean",
      "default": false
    },
    "sections_completed": {
      "type": "integer",
      "default": 0
    },
    "sections_total": {
      "type": "integer",
      "default": 1
    },
    "assembly_status": {
      "type": "string",
      "default": "pending"
    },
    "ensemble_section_outputs": {
      "type": "object"
    },
    "fallback_triggered": {
      "type": "boolean",
      "default": false
    },
    "generation_time_ms": {
      "type": "integer"
    },
    "prior_sale_price": {
      "type": "number",
      "description": "Last known sale price for this property in dollars."
    },
    "prior_sale_year": {
      "type": "number",
      "description": "4-digit year of the prior sale."
    },
    "agent_comps": {
      "type": "array",
      "description": "Agent-confirmed comp set after review. The ONLY comp data passed to AI.",
      "items": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "sale_price": {
            "type": "number"
          },
          "sale_date": {
            "type": "string"
          },
          "sqft": {
            "type": "number"
          },
          "bedrooms": {
            "type": "number"
          },
          "bathrooms": {
            "type": "number"
          },
          "price_per_sqft": {
            "type": "number"
          },
          "source": {
            "type": "string"
          },
          "perplexity_confirmed": {
            "type": "boolean"
          },
          "perplexity_variance": {
            "type": "number"
          },
          "condition_vs_subject": {
            "type": "string"
          },
          "agent_excluded": {
            "type": "boolean"
          },
          "agent_notes": {
            "type": "string"
          }
        }
      }
    },
    "comps_source": {
      "type": "string",
      "enum": [
        "api_verified",
        "agent_manual",
        "mixed",
        "none"
      ],
      "default": "none"
    },
    "raw_batchdata_comps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "raw_perplexity_enrichment": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "comps_fetched_at": {
      "type": "string",
      "format": "date-time"
    },
    "comps_search_tier": {
      "type": "string"
    },
    "comps_search_radius": {
      "type": "number"
    },
    "large_property_flag": {
      "type": "boolean",
      "default": false
    },
    "comps_researcher_note": {
      "type": "string"
    },
    "comps_fetch_triggered": {
      "type": "boolean",
      "default": false
    },
    "comps_cache_key": {
      "type": "string"
    },
    "valuation_anomaly": {
      "type": "object"
    },
    "override_acknowledged": {
      "type": "boolean",
      "default": false
    },
    "override_acknowledged_by": {
      "type": "string"
    },
    "override_acknowledged_at": {
      "type": "string",
      "format": "date-time"
    },
    "seller_mortgage_payoff": {
      "type": "number"
    },
    "seller_mortgage_known": {
      "type": "boolean",
      "default": false
    },
    "seller_commission_rate": {
      "type": "number"
    },
    "seller_closing_cost_rate": {
      "type": "number"
    },
    "seller_other_costs": {
      "type": "number"
    },
    "net_proceeds_json": {
      "type": "object"
    },
    "low_comp_acknowledged": {
      "type": "boolean",
      "default": false
    },
    "low_comp_count": {
      "type": "integer"
    },
    "listing_photos": {
      "type": "array",
      "description": "URLs of uploaded or AI-fetched listing photos. Used for vision-based condition scoring.",
      "items": {
        "type": "string"
      }
    },
    "condition_override": {
      "type": "string",
      "enum": [
        "fully_renovated",
        "updated",
        "original_good",
        "needs_work"
      ],
      "description": "Agent-specified condition level used when no photos are provided."
    },
    "photo_condition_analysis": {
      "type": "object",
      "description": "AI vision analysis result from listing photos \u2014 condition, finish level, PPSF adjustment recommendation."
    }
  },
  "required": [
    "run_by_email",
    "assessment_type",
    "property_type",
    "ai_platform"
  ]
}